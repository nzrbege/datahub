{
    "name": "laravel/data-keluarga-pdp",
    "description": "Sistem Manajemen Data Keluarga - Compliant UU PDP No.27/2022",
    "keywords": ["laravel", "pdp", "data-pribadi"],
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-activitylog": "^4.7",
        "maatwebsite/excel": "^3.1",
        "mews/captcha": "^3.3",
        "intervention/image": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "post-install-cmd": ["@php artisan package:discover --ansi"],
        "post-update-cmd": ["@php artisan package:discover --ansi"]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
